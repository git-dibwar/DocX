  },
  "dependencies": {
    "docx": "^9.0.1",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "mammoth": "^1.8.0",
    "multer": "^1.4.5-lts.1",
    "pdf-lib": "^1.17.1",
    "stripe": "^16.5.0"
  }
}
